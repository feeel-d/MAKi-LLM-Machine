VITE_API_BASE_URL=https://your-funnel-url.ts.net
GATEWAY_PORT=3001
# 기본 127.0.0.1 — 같은 Tailnet에서 다른 기기가 100.x.x.x:3001 로 붙게 하려면 0.0.0.0
GATEWAY_HOST=127.0.0.1
LLAMA_SERVER_URL=http://127.0.0.1:8081
LLAMA_API_KEY=
# GitHub Pages·로컬 Vite. 외부 도메인은 쉼표로 추가. 전체 허용은 * (브라우저 Origin 그대로 반환)
# Tailscale Funnel(https://*.ts.net) 출처는 게이트웨이가 자동 허용(별도 나열 불필요)
ALLOWED_ORIGINS=https://feeel-d.github.io,http://localhost:5173,http://127.0.0.1:5173
RATE_LIMIT_BURST=4
RATE_LIMIT_BURST_WINDOW_MS=10000
RATE_LIMIT_MINUTE=12
QUEUE_CAPACITY=2
QUEUE_MAX_PENDING=8
REQUEST_TIMEOUT_MS=180000
MAX_BODY_BYTES=65536
SERVICE_API_KEY=replace-with-internal-service-key
CONTENT_RETRY_COUNT=1
IMAGE_FETCH_TIMEOUT_MS=15000
MAX_IMAGE_BYTES=8388608
ALLOWED_IMAGE_MIME=image/jpeg,image/png,image/webp,image/gif
MODELS_DIR=$HOME/models
DEEPSEEK_MODEL_PATH=$HOME/models/deepseek.gguf
QWEN_MODEL_PATH=$HOME/models/qwen.gguf
GEMMAE4_HF_REPO=ggml-org/Qwen2-VL-2B-Instruct-GGUF
ROUTER_MMPROJ_OFFLOAD=0
GEMMAE4_N_GPU_LAYERS=0
DEEPSEEK_CTX=16384
QWEN_CTX=16384
